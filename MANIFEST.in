include README.md
include LICENSE
include CMakeLists.txt
include pyproject.toml
recursive-include cmake *.cmake
recursive-include cpp *.cpp *.cu *.cuh *.hpp CMakeLists.txt
recursive-include docs *.md
recursive-include benchmarks *.py
recursive-include pixinsight *.md *.js
recursive-include packaging *.md *.ps1 *.iss
recursive-include tests *.py
prune runs
prune build
prune dist
prune .venv
prune .pytest_cache
prune .ruff_cache
global-exclude __pycache__/*
global-exclude *.py[cod]
global-exclude *.pyd
global-exclude *.pdb
global-exclude *.ilk
global-exclude *.so
global-exclude *.dll
